describe("main", () => {
  test("--help prints usage and exits", async () => {
    const exitSpy = spyOn(process, "exit").mockImplementation(() => {
      throw new Error("exit");
    });

    try {
      await expect(main(["--help"])).rejects.toThrow("exit");
      expect(exitSpy).toHaveBeenCalledWith(0);
    } finally {
      exitSpy.mockRestore();
    }
  });

  test("exits when config not found", async () => {
    // Implementation would go here
  });

  test("exits when no valid repos found", async () => {
    // Implementation would go here
  });

  test("warns about missing repos", async () => {
    // Implementation would go here
  });

  test("shows dry-run message", async () => {
    // Implementation would go here
  });

  test("shows no-PRs message when no changes", async () => {
    // Implementation would go here
  });

  test("shows PR URLs and opens in browser when confirmed", async () => {
    // Implementation would go here
  });

  test("does not open browser when declined", async () => {
    // Implementation would go here
  });

  test("exits when user cancels PR confirmation", async () => {
    // Implementation would go here
  });

  test("openURLs launches correct command for each platform", () => {
    const spawnSpy = spyOn(Bun, "spawn").mockReturnValue(
      {} as ReturnType<typeof Bun.spawn>
    );

    try {
      // Test win32
      openURLs(["https://example.com/1"], "win32");
      expect(spawnSpy).toHaveBeenLastCalledWith(
        ["cmd", "/c", "start", "", "https://example.com/1"],
        {
          stdout: "ignore",
          stderr: "ignore",
        }
      );

      // Test darwin
      spawnSpy.mockClear();
      openURLs(["https://example.com/2"], "darwin");
      expect(spawnSpy).toHaveBeenLastCalledWith(
        ["open", "https://example.com/2"],
        {
          stdout: "ignore",
          stderr: "ignore",
        }
      );

      // Test linux
      spawnSpy.mockClear();
      openURLs(["https://example.com/3"], "linux");
      expect(spawnSpy).toHaveBeenLastCalledWith(
        ["xdg-open", "https://example.com/3"],
        {
          stdout: "ignore",
          stderr: "ignore",
        }
      );
    } finally {
      spawnSpy.mockRestore();
    }
  });

  test("openURLBun spawns URL with Bun", () => {
    const spawnSpy = spyOn(Bun, "spawn").mockReturnValue(
      {} as ReturnType<typeof Bun.spawn>
    );

    try {
      openURLBun(["open", "https://example.com"]);
      expect(spawnSpy).toHaveBeenCalledWith(["open", "https://example.com"], {
        stdout: "ignore",
        stderr: "ignore",
      });
    } finally {
      spawnSpy.mockRestore();
    }
  });

  test("openURLNodejs uses child_process spawn", async () => {
    // Use cross-platform command that exists
    const testCmd =
      process.platform === "win32"
        ? ["cmd", "/c", "echo", "test"]
        : ["echo", "test"];

    await openURLNodejs(testCmd);
    // If it succeeds, that's fine
  });

  test("openURLs handles empty URL list", () => {
    // Test that openURLs doesn't throw with empty list
    expect(() => {
      openURLs([]);
    }).not.toThrow();
  });

  test("openURLs uses Node.js fallback when Bun is undefined", () => {
    // Save original value
    const originalBun = (global as any).Bun;
    // Mock Bun as undefined
    (global as any).Bun = undefined;

    try {
      // Spy on openURLNodejs to see if it gets called
      const openURLNodejsSpy = spyOn(
        { openURLNodejs } as { openURLNodejs: typeof openURLNodejs },
        "openURLNodejs"
      ).mockImplementation(() => Promise.resolve());

      // Call openURLs
      openURLs(["https://example.com"]);

      // Verify openURLNodejs was called (Bun fallback path)
      expect(openURLNodejsSpy).toHaveBeenCalled();
    } finally {
      // Restore original Bun
      (global as any).Bun = originalBun;
    }
  });
});
