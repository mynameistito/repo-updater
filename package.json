{
  "name": "repo-updater",
  "version": "0.4.0",
  "description": "CLI tool to mass-update dependencies across multiple git repositories with auto package manager detection (npm, pnpm, yarn, Bun)",
  "type": "module",
  "license": "MIT",
  "author": "mynameistito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/repo-updater.git"
  },
  "bugs": {
    "url": "https://github.com/mynameistito/repo-updater/issues"
  },
  "homepage": "https://github.com/mynameistito/repo-updater#readme",
  "keywords": [
    "bun",
    "npm",
    "pnpm",
    "yarn",
    "dependencies",
    "updater",
    "cli",
    "monorepo",
    "automation",
    "github",
    "package-manager",
    "batch-update"
  ],
  "bin": {
    "repo-updater": "src/cli.ts"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22.0.0"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "test:node": "vitest run",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build && bun run typecheck",
    "version": "changeset version"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-result": "^2.7.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
    "lefthook": "^2.1.4",
    "ultracite": "^7.3.2",
    "v8r": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "brace-expansion": ">=5.0.5",
    "picomatch": ">=4.0.4"
  }
}
