{
  "name": "repo-updater-root",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run --filter '*' check",
    "fix": "bun run --filter '*' fix",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter 'repo-updater' test",
    "test:node": "bun run --filter 'repo-updater' test:node",
    "sync:jsr": "bun run --filter 'repo-updater' sync:jsr",
    "version": "changeset version && bun run sync:jsr && bunx ultracite fix packages/repo-updater/deno.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.30.0",
    "lefthook": "^2.1.5",
    "ultracite": "^7.5.8",
    "v8r": "^6.0.0"
  }
}
