{
  "name": "repo-updater",
  "version": "0.7.2",
  "description": "CLI tool to mass-update dependencies across multiple git repositories with auto package manager detection (npm, pnpm, yarn, Bun)",
  "type": "module",
  "license": "MIT",
  "author": "mynameistito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mynameistito/repo-updater.git",
    "directory": "packages/repo-updater"
  },
  "bugs": {
    "url": "https://github.com/mynameistito/repo-updater/issues"
  },
  "homepage": "https://github.com/mynameistito/repo-updater#readme",
  "keywords": [
    "bun",
    "npm",
    "pnpm",
    "yarn",
    "dependencies",
    "updater",
    "cli",
    "monorepo",
    "automation",
    "github",
    "package-manager",
    "batch-update"
  ],
  "bin": {
    "repo-updater": "./dist/cli.mjs"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22.6.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "test:node": "vitest run",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "build": "tsdown",
    "sync:jsr": "bun scripts/sync-jsr-version.ts",
    "prepublishOnly": "bun run build && bun run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "better-result": "^2.8.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260414.1",
    "publint": "^0.3.18",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "brace-expansion": ">=5.0.5",
    "picomatch": ">=4.0.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "import": "./dist/cli.mjs"
    },
    "./package.json": "./package.json"
  }
}
